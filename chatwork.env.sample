# ChatWork 連携用 環境変数
# 使い方: cp chatwork.env.sample chatwork.env して値を埋める
# chatwork.env は .gitignore 済み (*.env パターン) → コミット禁止

# -----------------------------------------------------------------
# ① ChatWork API Token (Hermes が ChatWork へ投稿するため)
# 取得: https://www.chatwork.com/service/packages/chatwork/subpackages/api/token.php
# -----------------------------------------------------------------
CHATWORK_API_TOKEN=your-chatwork-api-token-here

# -----------------------------------------------------------------
# ② ChatWork Webhook 用 設定 (ChatWork → Hermes 受信)
# -----------------------------------------------------------------

# Webhook シークレット (HMAC-SHA256 検証用)
# 取得: ChatWork → サービス連携 → Webhook → 新規Webhook作成 → シークレットトークン表示
# Lambda Router で X-ChatWorkWebhookSignature ヘッダ検証に使用
CHATWORK_WEBHOOK_TOKEN=your-webhook-secret-here

# Bot自身の account_id (mention検知や自己ループ防止に使用)
# 確認: ChatWork → 自分のプロフィール → URL末尾の数字 (https://www.chatwork.com/#!ridXXX)
# または GET /me APIで取得 ({"account_id":12345,...})
CHATWORK_BOT_ACCOUNT_ID=

# bot が応答する許可ルームID (カンマ区切り、空なら全ルーム許可)
# 例: "123456789,987654321"
CHATWORK_ALLOWED_ROOM_IDS=
