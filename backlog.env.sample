# Backlog 連携用 環境変数
# 使い方: cp backlog.env.sample backlog.env して値を埋める
# backlog.env は .gitignore 済み (*.env パターン) → コミット禁止

# Backlog スペースID (例: yourspace.backlog.com なら "yourspace")
BACKLOG_SPACE_ID=

# Backlog ドメイン (backlog.com / backlog.jp / backlog.co)
BACKLOG_DOMAIN=backlog.com

# Backlog API Key
# 取得: <space>.backlog.com → 個人設定 → API → 新しいAPIキーを発行
# 例: https://yourspace.backlog.com/EditApiSettings.action
BACKLOG_API_KEY=

# 既定プロジェクトキー (省略可、空ならツール呼出時に毎回指定)
BACKLOG_DEFAULT_PROJECT_KEY=
