# ============================================================
# Hermes Agent on AWS Bedrock - 環境変数雛形
# ============================================================
# 使い方:
#   1. このファイルを .env にコピー
#      cp .env.example .env
#   2. エディタで .env の各値を埋める
#   3. .env は .gitignore 済み → コミット禁止
# ============================================================

# ------------------------------------------------------------
# AWS 認証（IAM Access Key 方式）
# ------------------------------------------------------------
# IAM Console で専用ユーザー hermes-deploy-bot 作成
# - MFA 必須
# - 最小権限ポリシー（Bedrock / Lambda / EventBridge / S3 / DynamoDB / IAM:CreateRole）
# - root キー使用禁止
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1
AWS_ACCOUNT_ID=

# プロファイル名で aws-cli を使う場合（Access Key と排他、どちらか片方）
# AWS_PROFILE=hermes-deploy

# ------------------------------------------------------------
# Bedrock（Claude モデル）
# ------------------------------------------------------------
# Tokyo リージョン推奨モデル ID:
#   - us.anthropic.claude-sonnet-4-5-20250929-v1:0  (Sonnet 4.5)
#   - us.anthropic.claude-opus-4-5-20251101-v1:0    (Opus 4.5)
# 事前に Bedrock Console → Model access でアクセス有効化
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_REGION=us-east-1

# ------------------------------------------------------------
# Hermes Agent 基本設定
# ------------------------------------------------------------
HERMES_HOME=/Users/tobisako/dev/claude_code/gj-board-management/ceo-office/HermesAgent
HERMES_DATA_DIR=${HERMES_HOME}/hermes_data
HERMES_LOG_LEVEL=info
HERMES_DEFAULT_MODEL=bedrock:${BEDROCK_MODEL_ID}

# ------------------------------------------------------------
# AgentCore / Lambda（Phase 2 以降で使用）
# ------------------------------------------------------------
# CDK デプロイ後 出力値を貼る
AGENTCORE_RUNTIME_ARN=
LAMBDA_ROUTER_FUNCTION_NAME=
S3_STATE_BUCKET=
DYNAMODB_SESSION_TABLE=

# ------------------------------------------------------------
# ChatWork 連携（Phase 3 で改造後に有効化）
# ------------------------------------------------------------
# https://www.chatwork.com/service/packages/chatwork/subpackages/api/token.php
# CHATWORK_API_TOKEN=
# CHATWORK_ROOM_ID=
# CHATWORK_WEBHOOK_TOKEN=

# ------------------------------------------------------------
# 他プラットフォーム（任意・未使用ならコメントアウトのまま）
# ------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# DISCORD_BOT_TOKEN=
