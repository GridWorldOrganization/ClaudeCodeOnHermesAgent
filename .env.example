# ============================================================
# Hermes Agent on AWS Bedrock — 環境変数雛形
# ============================================================
# 使い方:
#   1. このファイルを .env にコピー
#      cp .env.example .env
#   2. エディタで .env の各値を埋める
#   3. .env は .gitignore 済み → コミット禁止
# ============================================================

# ------------------------------------------------------------
# AWS 認証（IAM Access Key 方式）
# ------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1
AWS_ACCOUNT_ID=

# プロファイル名で aws-cli を使う場合（Access Key と排他）
# AWS_PROFILE=hermes-deploy

# ------------------------------------------------------------
# Bedrock / AgentCore
# ------------------------------------------------------------
# CDK デプロイ後に cdk.json の agentcore_runtime_arn を更新するか
# こちらの env var に設定する
AGENTCORE_RUNTIME_ARN=
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6
BEDROCK_REGION=ap-northeast-1

# ------------------------------------------------------------
# ChatWork 連携（Phase 3 / hermes_chatwork_consumer Lambda）
# ------------------------------------------------------------
# https://www.chatwork.com/service/packages/chatwork/subpackages/api/token.php
CHATWORK_API_TOKEN=
CHATWORK_BOT_ACCOUNT_ID=
CHATWORK_ALLOWED_ROOM_IDS=   # カンマ区切り、空=全許可

# ChatWork webhook HMAC 検証シークレット
# CHATWORK_WEBHOOK_TOKEN=

# ------------------------------------------------------------
# Backlog MCP 連携（任意）
# ------------------------------------------------------------
# BACKLOG_DOMAIN=yourspace.backlog.com
# BACKLOG_API_KEY=
# BACKLOG_DEFAULT_PROJECT_KEY=

# ------------------------------------------------------------
# 他プラットフォーム（任意・未使用ならコメントのまま）
# ------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# DISCORD_BOT_TOKEN=
